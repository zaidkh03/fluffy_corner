@{
    ViewData["Title"] = "Categories";
}

<section class="categories-page">
    <div class="container">

        <div class="text-center mb-5">
            <p class="category-small">Collections</p>
            <h1 class="category-title">Shop By Pet Type</h1>
        </div>

        <div class="row justify-content-center g-4">

            <div class="col-lg-4 col-md-6">
                <a href="/Products?category=Cats" class="big-category-card">
                    <div class="big-category-icon">🐱</div>
                    <h3>Cats</h3>
                    <p>Food, beds, toys, and accessories for cats.</p>
                    <span>Shop Cats →</span>
                </a>
            </div>

            <div class="col-lg-4 col-md-6">
                <a href="/Products?category=Dogs" class="big-category-card">
                    <div class="big-category-icon">🐶</div>
                    <h3>Dogs</h3>
                    <p>Food, beds, toys, and accessories for dogs.</p>
                    <span>Shop Dogs →</span>
                </a>
            </div>

        </div>

    </div>
</section>
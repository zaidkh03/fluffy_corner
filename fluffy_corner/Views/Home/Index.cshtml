@model List<fluffy_corner.Models.Product>

@{
    var wishlistProductIds = ViewBag.WishlistProductIds as List<int> ?? new List<int>();
}
<section class="hero-slider">

    <div class="hero-slide slide-1 active">

        <div class="hero-text">
            <p class="hero-small">True Companions</p>

            <h1 class="hero-title">
                Love, Treats, <br />
                And Tails
            </h1>

            <p class="hero-desc">
                Discover the best food, toys, and accessories
                for your lovely pets.
            </p>

            <a href="#" class="shop-btn">
                Shop Now
            </a>
        </div>

        <div class="hero-img-col">
            <img src="/images/dooog.png"
                 class="hero-pet-img" />
        </div>

    </div>

    <div class="hero-slide slide-2">

        <div class="hero-text">
            <p class="hero-small">Healthy Pets</p>

            <h1 class="hero-title">
                Premium Care <br />
                For Your Friends
            </h1>

            <p class="hero-desc">
                High-quality products carefully selected
                for cats and dogs.
            </p>

            <a href="#" class="shop-btn">
                Explore
            </a>
        </div>

        <div class="hero-img-col">
            <img src="/images/pet_nobg.png"
                 class="hero-pet-img" />
        </div>

    </div>

    <button class="arrow arrow-prev"
            onclick="changeSlide(-1)">
        ‹
    </button>

    <button class="arrow arrow-next"
            onclick="changeSlide(1)">
        ›
    </button>

    <div class="slider-dots">
        <button class="dot active"
                onclick="goSlide(0)"></button>

        <button class="dot"
                onclick="goSlide(1)"></button>
    </div>

</section>

<section class="category-section">

    <div class="section-top">
        <p class="category-small">Pet Picks</p>

        <h2 class="category-title">
            Everything Your Pet Needs
        </h2>
    </div>

    <div class="cat-grid">

        <a href="#" class="category-card">

            <div class="cat-img-wrap">
                <img src="/images/DOG.jpg" />
            </div>

            <div class="cat-body">
                <h4>Dogs</h4>


                <span class="cat-arr">→</span>
            </div>

        </a>

        <a href="#" class="category-card">

            <div class="cat-img-wrap">
                <img src="/images/CAT.jpg" />
            </div>

            <div class="cat-body">
                <h4>Cat</h4>


                <span class="cat-arr">→</span>
            </div>

        </a>

    </div>

</section>

<section class="products-section">

    <div class="products-header">

        <div>
            <p class="section-small">Popular Products</p>

            <h2 class="section-title">
                Best Sellers
            </h2>
        </div>

        <a href="#" class="view-all-link">
            View All
        </a>

    </div>

    <div class="prod-grid">

        @foreach (var product in Model)
        {
            var image = product.Images.FirstOrDefault()?.ImageUrl;

            if (string.IsNullOrEmpty(image))
            {
                image = "/images/cat-error.png";
            }

            var isFavorite = wishlistProductIds.Contains(product.Id);

            <div class="product-card">

                <div class="prod-img-wrap">

                    @if (product.DiscountPercentage != null)
                    {
                        <span class="discount-badge">
                            -@product.DiscountPercentage%
                        </span>
                    }

                    <form asp-controller="Wishlist"
                          asp-action="Add"
                          method="post">

                        @Html.AntiForgeryToken()

                        <input type="hidden"
                               name="productId"
                               value="@product.Id" />

                        <button type="submit"
                                class="heart-btn @(isFavorite ? "favorite-active" : "")">

                            @(isFavorite ? "♥" : "♡")

                        </button>

                    </form>

                    <img src="@image"
                         class="product-img"
                         alt="@product.Name" />

                </div>

                <div class="prod-body">

                    <h4>@product.Name</h4>

                    <div class="prod-footer">

                        <span class="prod-price">
                            $@product.Price
                        </span>

                        <button class="add-to-cart">
                            +
                        </button>

                    </div>

                </div>

            </div>
        }

    </div>

</section>

<section class="testimonial-section">

    <div class="test-inner">

        <div class="test-left">

            <p class="testimonial-small">
                Testimonials
            </p>

            <h2 class="testimonial-title">
                Loved By Pet Owners
            </h2>

        </div>

        <div class="testimonial-card">

            <div class="stars">
                ★★★★★
            </div>

            <div class="test-content-row">

                <img src="/images/user.jpg"
                     class="testimonial-img" />

                <div>

                    <h4>Sarah Johnson</h4>

                    <p>
                        Amazing products and fast delivery.
                        My cat absolutely loves the food!
                    </p>

                </div>

            </div>

        </div>

    </div>

</section>
<footer class="main-footer">

    <div class="footer-container">

        <div class="footer-brand">

            <h2>🐾 Fluffy Corner</h2>

            <p>
                Your lovely place for pet food,
                toys, accessories and care.
            </p>

        </div>

        <div class="footer-links">

            <h4>Quick Links</h4>

            <a href="#">Home</a>
            <a href="#">Shop</a>
            <a href="#">Categories</a>
            <a href="#">Wishlist</a>

        </div>

        <div class="footer-links">

            <h4>Support</h4>

            <a href="#">Contact</a>
            <a href="#">FAQ</a>
            <a href="#">Privacy Policy</a>

        </div>

        <div class="footer-newsletter">

            <h4>Newsletter</h4>

            <p>
                Subscribe for new offers & updates.
            </p>

            <div class="newsletter-box">

                <input type="email"
                       placeholder="Your Email" />

                <button>
                    →
                </button>

            </div>

        </div>

    </div>

    <div class="footer-bottom">

        © 2026 Fluffy Corner — All Rights Reserved

    </div>

</footer>
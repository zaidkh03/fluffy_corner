<div class="d-flex justify-content-center align-items-center vh-100 bg-light">
    <div class="card p-5 shadow-sm text-center" style="width: 100%; max-width: 500px; border-radius: 15px; border: none;">

        <div class="mb-4">
            <i class="fas fa-exclamation-triangle text-warning" style="font-size: 4rem;"></i>
        </div>

        <h2 class="fw-bold text-danger mb-2">Access Denied</h2>
        <p class="text-muted mb-4">Sorry, you do not have permission to view this page. If you think this is a mistake, please contact the administrator.</p>

        <div class="d-grid gap-2">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary fw-bold" style="border-radius: 10px; padding: 12px;">
                Go to Homepage
            </a>
            <a asp-action="Login" class="btn btn-link text-decoration-none text-muted small">
                Sign in with a different account
            </a>
        </div>
    </div>
</div>

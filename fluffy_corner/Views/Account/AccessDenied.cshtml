@{
    Layout = "_Layout"; 
}

<div class="container text-center d-flex flex-column align-items-center justify-content-center" style="min-height: 80vh; background-color: #f8faff;">

    
    <div class="error-illustration mb-4" style="position: relative; display: inline-block;">
        <h1 style="font-size: 10rem; font-weight: 900; color: #2d3436; opacity: 0.1; margin: 0;">403</h1>

      
        <img src="/images/cat-error.png"
             alt="Access Denied"
             style="width: 300px; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);">
    </div>

    <!-- النصوص -->
    <div class="error-content">
        <h2 class="fw-bold" style="color: #2d3436; font-size: 2.5rem;">OOPS...</h2>
        <p class="text-muted mb-4" style="font-size: 1.2rem;">YOU DON'T HAVE PERMISSION TO ACCESS THIS PAGE</p>
    </div>

    <!-- الزر بنفس اللون والشكل الموجود في الصورة -->
    <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-5 py-2 shadow-sm"
       style="background-color: #4466d1; border: none; border-radius: 25px; font-weight: 500; transition: 0.3s;">
        Go back to Home
    </a>
</div>

<style>
    /* تأثير بسيط عند تمرير الماوس على الزر */
    .btn-primary:hover {
        background-color: #3554b5 !important;
        transform: translateY(-2px);
    }

    /* جعل رقم الخلفية يستجيب لحجم الشاشة */
    @@media (max-width: 768px) {
        h1 {
            font-size: 6rem !important;
        }

        img {
            width: 200px !important;
        }
    }
</style>
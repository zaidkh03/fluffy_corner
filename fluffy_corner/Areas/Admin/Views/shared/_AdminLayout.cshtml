<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FluffyCorner Admin</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <!-- Custom Layout CSS -->
    <link rel="stylesheet" href="~/admin/css/admin-layout.css" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <div class="d-flex">
        <!-- Sidebar -->
        <nav id="sidebar">
            <div class="sidebar-header d-flex align-items-center">
                <img src="~/images/Fluffy-logo.png" alt="Fluffy" height="70" width="70" ">
            </div>

            <p>Main Menu</p>
            <ul class="list-unstyled components mt-4">
                
                <li class="@(ViewContext.RouteData.Values["Controller"].ToString() == "Dashboard" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                        <i class="fas fa-th-large"></i> Dashboard
                    </a>
                </li>
                <li>
                    <a href="#"><i class="fas fa-shopping-bag"></i> Orders</a>
                </li>
                <li>
                    <a href="#"><i class="fas fa-bone"></i> Products</a>
                </li>

                <p>Content Management</p>
                <li>
                    <a href="#"><i class="fas fa-quote-left"></i> Testimonials</a>
                </li>
                <li>
                    <a href="#"><i class="fas fa-comment-alt"></i> Comments</a>
                </li>

                <p>Settings</p>
                <li>
                    <a href="#"><i class="fas fa-user-shield"></i> Roles</a>
                </li>
                <li>
                    <a href="#"><i class="fas fa-cog"></i> Site Settings</a>
                </li>
            </ul>
        </nav>

        <!-- Page Content Area -->
        <div id="content">
            <!-- Top Navbar -->
            <nav class="navbar navbar-expand-lg admin-navbar">
                <div class="container-fluid">
                    <button type="button" id="sidebarCollapse" class="btn btn-light">
                        <i class="fas fa-align-left"></i>
                    </button>

                    <div class="ms-auto d-flex align-items-center">
                        <div class="dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" role="button" data-bs-toggle="dropdown">
                                <span class="me-2 d-none d-md-inline fw-semibold">Admin Name</span>
                                <img src="https://ui-avatars.com/api/?name=Admin&background=FFD200&color=1A1C1E" class="user-profile-img">
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-3" style="border-radius: 15px;">
                                <li><a class="dropdown-item" href="#"><i class="fas fa-user me-2"></i> Profile</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="#"><i class="fas fa-sign-out-alt me-2"></i> Logout</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </nav>

            <!-- Main Body Wrapper -->
            <div class="p-4">
                @RenderBody()
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#sidebarCollapse').on('click', function () {
                $('#sidebar').toggleClass('active');
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
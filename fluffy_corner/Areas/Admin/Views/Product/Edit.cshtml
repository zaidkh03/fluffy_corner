@model fluffy_corner.Models.Product
@using fluffy_corner.Models

@{
    ViewData["Title"] = "Edit Product";
    var categories = ViewBag.Categories as List<Category>;
    var imageUrl = ViewBag.PrimaryImage as string;
}

<div class="edit-product-page">

    <div class="top-header">

        <div>
            <span class="page-tag">Admin Dashboard</span>

            <h1>Edit Product</h1>

            <p>
                Update product details, stock, and visibility.
            </p>
        </div>

        <a href="/Admin/Product"
           class="back-btn">
            ← Back
        </a>

    </div>

    <div class="form-card">

        <form action="/Admin/Product/Edit/@Model.Id"
              method="post"
              enctype="multipart/form-data">

            @Html.AntiForgeryToken()

            <input type="hidden"
                   name="Id"
                   value="@Model.Id" />

            <div class="form-grid">

                <div class="form-group">
                    <label>Product Name</label>

                    <input name="Name"
                           value="@Model.Name"
                           required />
                </div>

                <div class="form-group">
                    <label>SKU</label>

                    <input name="SKU"
                           value="@Model.SKU"
                           required />
                </div>

                <div class="form-group">
                    <label>Brand</label>

                    <input name="Brand"
                           value="@Model.Brand" />
                </div>

                <div class="form-group">
                    <label>Price</label>

                    <input name="Price"
                           type="number"
                           step="0.01"
                           value="@Model.Price"
                           required />
                </div>

                <div class="form-group">
                    <label>Discount %</label>

                    <input name="DiscountPercentage"
                           type="number"
                           step="0.01"
                           value="@Model.DiscountPercentage" />
                </div>

                <div class="form-group">
                    <label>Stock Quantity</label>

                    <input name="StockQuantity"
                           type="number"
                           value="@Model.StockQuantity"
                           required />
                </div>

                <div class="form-group">
                    <label>Weight</label>

                    <input name="Weight"
                           type="number"
                           step="0.01"
                           value="@Model.Weight" />
                </div>

                <div class="form-group">

                    <label>Animal Type</label>

                    <select name="AnimalType" required>

                        <option value="Cat"
                                selected="@(Model.AnimalType == "Cat")">
                            Cat
                        </option>

                        <option value="Dog"
                                selected="@(Model.AnimalType == "Dog")">
                            Dog
                        </option>

                        <option value="Both"
                                selected="@(Model.AnimalType == "Both")">
                            Both
                        </option>

                    </select>

                </div>

                <div class="form-group">

                    <label>Category</label>

                    <select name="CategoryId" required>

                        @if (categories != null)
                        {
                            foreach (var category in categories)
                            {
                        <option value="@category.Id"
                                selected="@(Model.CategoryId == category.Id)">
                            @category.Name
                        </option>
                            }
                        }

                    </select>

                </div>

                <div class="form-group">

                    <label>Upload New Product Image</label>

                    <input name="ImageFile"
                           type="file"
                           accept="image/*" />

                    @if (!string.IsNullOrEmpty(imageUrl))
                    {
                    <div class="current-image">

                        <p>Current Image</p>

                        <img src="@imageUrl" />

                    </div>
                    }

                </div>

            </div>

            <div class="form-group">

                <label>Short Description</label>

                <textarea name="ShortDescription"
                          rows="3">@Model.ShortDescription</textarea>

            </div>

            <div class="form-group">

                <label>Description</label>

                <textarea name="Description"
                          rows="6">@Model.Description</textarea>

            </div>

            <div class="checkboxes">

                <label>

                    <input type="checkbox"
                           name="IsFeatured"
                           value="true"
                           checked="@Model.IsFeatured" />

                    Featured Product

                </label>

                <label>

                    <input type="checkbox"
                           name="IsActive"
                           value="true"
                           checked="@Model.IsActive" />

                    Active Product

                </label>

            </div>

            <div class="buttons">

                <button type="submit"
                        class="save-btn">

                    Save Changes

                </button>

                <a href="/Admin/Product"
                   class="cancel-btn">

                    Cancel

                </a>

            </div>

        </form>

    </div>

</div>

<style>

    .edit-product-page {
        padding: 45px;
        background: #f8f7f4;
        min-height: 100vh;
        font-family: Arial, sans-serif;
    }

    .top-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

    .page-tag {
        background: #fff4d6;
        color: #c28a00;
        padding: 7px 14px;
        border-radius: 999px;
        font-weight: bold;
        font-size: 13px;
    }

    .top-header h1 {
        font-size: 42px;
        margin: 18px 0 10px;
        color: #1f2a3d;
    }

    .top-header p {
        color: #777;
        font-size: 17px;
    }

    .back-btn {
        background: white;
        padding: 14px 22px;
        border-radius: 12px;
        text-decoration: none;
        color: #1f2a3d;
        font-weight: bold;
        box-shadow: 0 8px 20px rgba(0,0,0,0.08);
    }

    .form-card {
        background: white;
        padding: 35px;
        border-radius: 22px;
        box-shadow: 0 12px 35px rgba(0,0,0,0.08);
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
    }

    .form-group {
        margin-bottom: 22px;
    }

        .form-group label {
            display: block;
            margin-bottom: 10px;
            font-weight: bold;
            color: #1f2a3d;
        }

        .form-group input,
        .form-group textarea,
        .form-group select {
            width: 100%;
            padding: 15px;
            border: 1px solid #e5e5e5;
            border-radius: 14px;
            font-size: 15px;
            outline: none;
        }

    .current-image {
        margin-top: 15px;
    }

        .current-image p {
            margin-bottom: 10px;
            font-weight: bold;
        }

        .current-image img {
            width: 120px;
            height: 120px;
            object-fit: cover;
            border-radius: 16px;
            border: 1px solid #eee;
        }

    .checkboxes {
        display: flex;
        gap: 25px;
        margin: 10px 0 30px;
    }

        .checkboxes label {
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: bold;
        }

    .buttons {
        display: flex;
        gap: 15px;
    }

    .save-btn {
        background: #f5b700;
        color: white;
        border: none;
        padding: 16px 28px;
        border-radius: 14px;
        font-size: 15px;
        font-weight: bold;
        cursor: pointer;
    }

    .cancel-btn {
        background: #f1f1f1;
        color: #333;
        padding: 16px 28px;
        border-radius: 14px;
        text-decoration: none;
        font-weight: bold;
    }

    @@media(max-width: 900px) {

        .form-grid {
            grid-template-columns: 1fr;
        }

        .top-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 20px;
        }
    }
</style>
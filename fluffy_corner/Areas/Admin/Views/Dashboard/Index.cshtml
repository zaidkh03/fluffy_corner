@{
    ViewData["Title"] = "Pawzy Dashboard";
    Layout = "_AdminLayout";
}

@section Styles {
    @* ربط ملف الـ CSS المنفصل الذي أنشأتِه في wwwroot *@
    <link rel="stylesheet" href="~/admin/css/dashboard.css" />
}

<div class="admin-dashboard-wrapper py-4 px-4">

    <!-- Header: ترحيب الأدمن -->
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold mb-1" style="color: var(--pawzy-dark);">Dashboard Overview</h2>
            <p class="text-muted">Welcome back! Here's what's happening at Pawzy today.</p>
        </div>
        <button class="btn btn-pawzy shadow-sm">
            <i class="fas fa-plus me-2"></i> New Product
        </button>
    </div>

    <!-- Stats Cards: عرض الأرقام القادمة من الـ Controller -->
    <div class="row g-4">

        <!-- كرت المستخدمين -->
        <div class="col-xl-3 col-md-6">
            <div class="card stat-card p-3">
                <div class="d-flex align-items-center">
                    <div class="icon-box bg-light-yellow">
                        <i class="fas fa-users"></i>
                    </div>
                    <div class="ms-3">
                        <h6 class="text-muted small mb-1">Total Users</h6>
                        <h3 class="fw-bold mb-0">@ViewBag.TotalUsers</h3>
                    </div>
                </div>
            </div>
        </div>

        <!-- كرت الطلبات -->
        <div class="col-xl-3 col-md-6">
            <div class="card stat-card p-3">
                <div class="d-flex align-items-center">
                    <div class="icon-box bg-light-blue">
                        <i class="fas fa-shopping-cart"></i>
                    </div>
                    <div class="ms-3">
                        <h6 class="text-muted small mb-1">Total Orders</h6>
                        <h3 class="fw-bold mb-0">@ViewBag.TotalOrders</h3>
                    </div>
                </div>
            </div>
        </div>

        <!-- كرت المنتجات -->
        <div class="col-xl-3 col-md-6">
            <div class="card stat-card p-3">
                <div class="d-flex align-items-center">
                    <div class="icon-box bg-light-success">
                        <i class="fas fa-bone"></i>
                    </div>
                    <div class="ms-3">
                        <h6 class="text-muted small mb-1">Products</h6>
                        <h3 class="fw-bold mb-0">@ViewBag.TotalProducts</h3>
                    </div>
                </div>
            </div>
        </div>

        <!-- كرت التصنيفات -->
        <div class="col-xl-3 col-md-6">
            <div class="card stat-card p-3">
                <div class="d-flex align-items-center">
                    <div class="icon-box bg-light-purple">
                        <i class="fas fa-tags"></i>
                    </div>
                    <div class="ms-3">
                        <h6 class="text-muted small mb-1">Categories</h6>
                        <h3 class="fw-bold mb-0">@ViewBag.TotalCategories</h3>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- قسم الرسوم البيانية -->
    <div class="row mt-5">
        <div class="col-lg-12">
            <div class="chart-container">
                <h5 class="fw-bold mb-4">Sales Analytics</h5>
                <canvas id="salesChart" height="100"></canvas>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <!-- استدعاء مكتبة الـ Charts وملف الـ JS الخاص بنا لاحقاً -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // كود تجريبي سريع للرسم البياني للتأكد من أن كل شيء يعمل
        const ctx = document.getElementById('salesChart').getContext('2d');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May'],
                datasets: [{
                    label: 'Sales',
                    data: [10, 25, 15, 40, 35],
                    borderColor: '#FFD200',
                    tension: 0.4
                }]
            }
        });
    </script>
}

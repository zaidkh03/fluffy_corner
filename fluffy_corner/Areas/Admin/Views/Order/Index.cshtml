@model List<fluffy_corner.ServiceLayer.DTOs.OrderSummaryDto>

@{
    ViewData["Title"] = "Order Management";
    Layout = "_AdminLayout";
}

<style>
    :root {
        --pawzy-peach: #FFEBE1; /* المشمشي اللطيف */
        --pawzy-yellow: #FFC400; /* الأصفر الحيوي للأزرار والمودال */
        --pawzy-dark: #1E2229; /* لون النصوص الرئيسي */
        --pawzy-white: #FFFFFF;
        --border-color: #E2E8F0;
    }

    .page-title {
        color: var(--pawzy-dark);
        font-weight: 800;
        letter-spacing: -0.5px;
    }

    /* بادج إجمالي الطلبات الحية */
    .badge-total {
        background-color: var(--pawzy-peach) !important;
        color: #B25329 !important;
        font-weight: 600;
        font-size: 0.9rem;
        border: 1px solid rgba(178, 83, 41, 0.15);
    }

    /* الكرت الرئيسي الحاضن للجدول */
    .fluffy-card {
        background: var(--pawzy-white) !important;
        border: 1px solid var(--border-color) !important;
        border-radius: 20px !important;
        overflow: hidden;
        box-shadow: 0 4px 12px rgba(30, 34, 41, 0.02) !important;
    }

    /* تصميم الجدول النظيف */
    .fluffy-table thead {
        background-color: #FAFAFA;
        border-bottom: 1px solid var(--border-color);
    }

    .fluffy-table th {
        color: #64748B !important;
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding: 16px 12px !important;
    }

    .fluffy-table td {
        padding: 16px 12px !important;
        border-bottom: 1px solid #F1F5F9 !important;
        color: var(--pawzy-dark);
        font-size: 0.95rem;
    }

    /* تخصيص الأفتار الافتراضي للزبون */
    .avatar-customer {
        background-color: var(--pawzy-peach) !important;
        color: #B25329 !important;
        font-weight: 700;
    }

    /* أزرار العمليات (Actions) الدائرية */
    .btn-action {
        background-color: #F1F5F9 !important;
        color: #475569 !important;
        border: none !important;
        border-radius: 10px !important;
        width: 36px;
        height: 36px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
    }

        .btn-action:hover {
            background-color: var(--pawzy-dark) !important;
            color: #FFFFFF !important;
        }

    /* البادجات الملونة لحالات الطلب المختلفة (Soft Status Pills) */
    .status-pill {
        padding: 6px 14px !important;
        border-radius: 50px !important;
        font-size: 0.85rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .status-pending {
        background-color: #FFF9E6;
        color: #CC9D00;
    }

    .status-shipped {
        background-color: #E0F2FE;
        color: #0369A1;
    }

    .status-completed {
        background-color: #E6F4EA;
        color: #137333;
    }

    .status-cancelled {
        background-color: #FCE8E6;
        color: #C5221F;
    }

    /* تخصيص الـ Modal ليتناسق مع الهوية */
    .pawzy-modal .modal-content {
        border-radius: 24px !important;
        border: none !important;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1) !important;
    }

    .pawzy-modal .modal-header {
        border-bottom: 1px solid #F1F5F9;
        padding: 20px 24px;
    }

    .pawzy-modal .modal-footer {
        border-top: 1px solid #F1F5F9;
        padding: 16px 24px;
    }

    .pawzy-select {
        padding: 12px !important;
        border-radius: 12px !important;
        border: 1px solid #CBD5E1 !important;
        color: var(--pawzy-dark) !important;
    }

        .pawzy-select:focus {
            border-color: var(--pawzy-yellow) !important;
            box-shadow: 0 0 0 3px rgba(255, 196, 0, 0.15) !important;
        }

    .btn-pawzy-save {
        background-color: var(--pawzy-yellow) !important;
        color: var(--pawzy-dark) !important;
        border-radius: 50px !important;
        font-weight: 700;
        border: none !important;
        padding: 10px 24px;
    }

        .btn-pawzy-save:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(255, 196, 0, 0.2);
        }
</style>

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h2 class="page-title mb-1">Order Management</h2>
            <p class="text-muted small mb-0">Track, filter, and process incoming pet shop orders</p>
        </div>
        <span class="badge badge-total px-3 py-2 rounded-pill">
            <i class="fas fa-shopping-basket me-2"></i>@Model.Count Live Orders
        </span>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 rounded-4 p-3 mb-4 shadow-sm" role="alert" style="background-color: #E6F4EA; color: #137333;">
            <i class="fas fa-check-circle messaging-icon me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 rounded-4 p-3 mb-4 shadow-sm" role="alert" style="background-color: #FCE8E6; color: #C5221F;">
            <i class="fas fa-exclamation-circle messaging-icon me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card fluffy-card">
        <div class="table-responsive">
            <table class="table fluffy-table align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Order ID</th>
                        <th>Customer</th>
                        <th>Date</th>
                        <th>Items Count</th>
                        <th>Total Amount</th>
                        <th>Status</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="fas fa-box-open fa-3x mb-3 d-block text-muted opacity-50"></i>
                                No orders found in the system database.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold" style="color: var(--pawzy-dark);">#@order.OrderId</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-customer me-2 rounded-circle d-flex align-items-center justify-content-center" style="width: 34px; height: 34px; font-size: 0.85rem;">
                                            @order.CustomerName.Substring(0, 1).ToUpper()
                                        </div>
                                        <span class="fw-semibold">@order.CustomerName</span>
                                    </div>
                                </td>
                                <td class="text-muted">@order.OrderDate.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <span class="badge px-2.5 py-1.5 rounded" style="background-color: #F1F5F9; color: #475569; font-weight: 600;">
                                        @order.ItemsCount pcs
                                    </span>
                                </td>
                                <td class="fw-bold" style="color: var(--pawzy-dark);">@order.TotalAmount.ToString("C2")</td>
                                <td>
                                    @{
                                        var (statusClass, iconClass) = order.Status switch
                                        {
                                            "Pending" => ("status-pending", "fa-clock"),
                                            "Shipped" => ("status-shipped", "fa-truck"),
                                            "Completed" => ("status-completed", "fa-check-circle"),
                                            "Cancelled" => ("status-cancelled", "fa-times-circle"),
                                            _ => ("status-pending", "fa-circle")
                                        };
                                    }
                                    <span class="status-pill @statusClass">
                                        <i class="fas @iconClass"></i> @order.Status
                                    </span>
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2">
                                        <a href="#" class="btn btn-action" title="View Order Details">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <button type="button"
                                                class="btn btn-action"
                                                onclick="openStatusModal(@order.OrderId, '@order.Status')"
                                                title="Change Order Status">
                                            <i class="fas fa-sliders-h"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade pawzy-modal" id="updateStatusModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-white">
            <div class="modal-header">
                <h5 class="modal-title fw-bold" style="color: var(--pawzy-dark);">Update Order Status</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-area="Admin" asp-controller="Order" asp-action="UpdateStatus" method="post">
                <div class="modal-body p-4">
                    <input type="hidden" id="modalOrderId" name="orderId" />

                    <div class="mb-2">
                        <label class="form-label fw-bold mb-2" style="color: var(--pawzy-dark);">Select New Status</label>
                        <select class="form-select pawzy-select" name="newStatus" id="modalStatusSelect">
                            <option value="Pending">Pending</option>
                            <option value="Shipped">Shipped</option>
                            <option value="Completed">Completed</option>
                            <option value="Cancelled">Cancelled</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light px-4 rounded-pill fw-semibold" data-bs-dismiss="modal" style="color: #64748B;">Cancel</button>
                    <button type="submit" class="btn btn-pawzy-save px-4 shadow-sm">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openStatusModal(id, currentStatus) {
            document.getElementById('modalOrderId').value = parseInt(id);
            document.getElementById('modalStatusSelect').value = currentStatus;

            var myModal = new bootstrap.Modal(document.getElementById('updateStatusModal'));
            myModal.show();
        }
    </script>
}